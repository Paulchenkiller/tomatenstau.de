{
  "name": "tomatenstaude",
  "version": "0.0.0",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "lint:eslint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint:eslint && npm run format:check",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed --project=chromium",
    "e2e:install": "playwright install",
    "test:mutation": "stryker run",
    "analyze": "ng build --stats-json && npx webpack-bundle-analyzer dist/tomatenstaude/stats.json",
    "lighthouse": "lhci autorun",
    "lighthouse:prod": "npm run build:compressed && lhci autorun --config lighthouserc.prod.js",
    "lighthouse:live": "lhci autorun --config lighthouserc.live.js",
    "start:prod": "ng build --configuration=production && npx http-server dist/tomatenstaude -p 4201 --cors",
    "a11y:test": "npm run e2e -- accessibility.spec.ts",
    "a11y:ci": "npm run a11y:test",
    "optimize:images": "node scripts/optimize-images.js",
    "compress:build": "node scripts/compress-build.js",
    "build:compressed": "ng build --configuration=production && npm run compress:build",
    "build:ssg": "ng build --configuration=production",
    "build:ssg:compressed": "ng build --configuration=production && npm run compress:build",
    "prepare": "husky",
    "lint:commit:last": "git log -1 --pretty=%B | commitlint",
    "serve:ssr:tomatenstaude": "node dist/tomatenstaude/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/platform-server": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@angular/ssr": "^21.2.3",
    "@fortawesome/angular-fontawesome": "^4.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@ngx-translate/core": "^17.0.0",
    "express": "^4.22.1",
    "flag-icons": "^7.5.0",
    "ngx-highlightjs": "^14.0.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-builders/jest": "^21.0.3",
    "@angular-devkit/build-angular": "^21.2.3",
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@axe-core/playwright": "^4.11.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@types/express": "^4.17.25",
    "@types/jasmine": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.57.1",
    "angular-eslint": "^21.3.1",
    "axe-core": "^4.11.1",
    "compression-webpack-plugin": "^12.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^62.5.4",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^5.5.5",
    "http-server": "^14.1.1",
    "husky": "^9.1.6",
    "jest": "^30.3.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.1",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "start-server-and-test": "^2.1.5",
    "ts-node": "~10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "webpack-bundle-analyzer": "^4.10.2"
  }
}
