---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PreviewNav from '../../components/PreviewNav.astro';
import { en as t } from '../../i18n/en';
---

<BaseLayout
  lang="en"
  title="Sidebar Preview – tomatenstau.de"
  description="Sidebar layout preview"
  skipToMain="Skip to main content"
>
  <div class="layout">
    <!-- Fixed left sidebar -->
    <aside class="sidebar" aria-label="Profile sidebar">
      <div class="sidebar__inner">
        <picture>
          <source srcset="/images/profilbild.webp" type="image/webp" />
          <img
            src="/images/profilbild.jpg"
            alt={t.index.profilePhotoAlt}
            class="sidebar__photo"
            width="140"
            height="140"
            loading="eager"
            fetchpriority="high"
          />
        </picture>

        <h1 class="sidebar__name">{t.index.name}</h1>
        <p class="sidebar__title">{t.index.jobTitle}</p>

        <hr class="sidebar__rule" />

        <nav class="sidebar__social" aria-label="Social links">
          <a href={t.social.github.url} target="_blank" rel="noopener noreferrer">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="16"
              height="16"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
              ></path></svg
            >
            GitHub
          </a>
          <a href={t.social.linkedin.url} target="_blank" rel="noopener noreferrer">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="16"
              height="16"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path></svg
            >
            LinkedIn
          </a>
          <a href={t.social.email.url}>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="16"
              height="16"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"
              ></path></svg
            >
            E-Mail
          </a>
        </nav>

        <hr class="sidebar__rule" />

        <div class="sidebar__meta">
          <span class="sidebar__meta-label">Location</span>
          <span>Germany</span>
        </div>
        <div class="sidebar__meta">
          <span class="sidebar__meta-label">Languages</span>
          <span>DE · EN</span>
        </div>
      </div>
    </aside>

    <!-- Scrollable content -->
    <main id="main-content" class="content">
      <section aria-labelledby="about-heading">
        <h2 id="about-heading" class="content__section-title">About</h2>
        <p class="content__lead">{t.index.intro}</p>
      </section>

      <section aria-labelledby="highlights-heading">
        <h2 id="highlights-heading" class="content__section-title">{t.index.highlightsHeading}</h2>
        <dl class="content__dl">
          <div class="content__dl-row">
            <dt>{t.index.highlights.focus}</dt>
            <dd>{t.index.highlights.focusText}</dd>
          </div>
          <div class="content__dl-row">
            <dt>{t.index.highlights.tech}</dt>
            <dd>{t.index.highlights.techText}</dd>
          </div>
          <div class="content__dl-row">
            <dt>{t.index.highlights.platforms}</dt>
            <dd>{t.index.highlights.platformsText}</dd>
          </div>
          <div class="content__dl-row">
            <dt>{t.index.highlights.domains}</dt>
            <dd>{t.index.highlights.domainsText}</dd>
          </div>
          <div class="content__dl-row">
            <dt>{t.index.highlights.certs}</dt>
            <dd>{t.index.highlights.certsText}</dd>
          </div>
        </dl>
      </section>
    </main>
  </div>

  <PreviewNav current="sidebar" />
</BaseLayout>

<style>
  :global(body) {
    margin: 0;
  }

  .layout {
    display: flex;
    min-height: 100vh;
    background: #0d1b2a;
    color: #a8b8cc;
    font-family: 'Merriweather', serif;
  }

  /* ── Sidebar ── */
  .sidebar {
    width: 260px;
    flex-shrink: 0;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    background: #091525;
    border-right: 1px solid #1a2d42;
    padding: 0;
  }

  .sidebar__inner {
    padding: 40px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .sidebar__photo {
    width: 120px;
    height: 120px;
    border-radius: 10px;
    object-fit: cover;
    border: 2px solid #1a2d42;
    margin-bottom: 4px;
  }

  .sidebar__name {
    font-family: 'Raleway', sans-serif;
    font-size: 20px;
    color: #e2eaf3;
    margin: 0;
  }

  .sidebar__title {
    font-size: 12px;
    color: #4a9eff;
    margin: 0;
    line-height: 1.5;
    font-family: system-ui, sans-serif;
  }

  .sidebar__rule {
    border: none;
    border-top: 1px solid #1a2d42;
    margin: 4px 0;
  }

  .sidebar__social {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sidebar__social a {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #7a92a8;
    text-decoration: none;
    font-size: 13px;
    font-family: system-ui, sans-serif;
    padding: 6px 8px;
    border-radius: 6px;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .sidebar__social a:hover {
    background: #1a2d42;
    color: #e2eaf3;
  }

  .sidebar__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 12px;
    font-family: system-ui, sans-serif;
  }

  .sidebar__meta-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #4a9eff;
  }

  /* ── Main content ── */
  .content {
    flex: 1;
    padding: 56px 60px;
    max-width: 760px;
  }

  .content__section-title {
    font-family: system-ui, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #4a9eff;
    margin: 0 0 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid #1a2d42;
  }

  .content__lead {
    font-size: 15px;
    line-height: 1.8;
    color: #8a9bb0;
    margin: 0 0 56px;
  }

  .content__dl {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0 0 56px;
  }

  .content__dl-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid #1a2d42;
    font-size: 14px;
    line-height: 1.6;
  }

  .content__dl-row dt {
    color: #e2eaf3;
    font-weight: normal;
    font-style: normal;
    font-family: system-ui, sans-serif;
    font-size: 13px;
  }

  .content__dl-row dd {
    margin: 0;
    color: #7a92a8;
    font-family: system-ui, sans-serif;
    font-size: 13px;
  }

  @media (max-width: 768px) {
    .layout {
      flex-direction: column;
    }
    .sidebar {
      width: 100%;
      height: auto;
      position: static;
    }
    .content {
      padding: 32px 24px;
    }
    .content__dl-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }
</style>
