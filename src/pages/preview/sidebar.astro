---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PreviewNav from '../../components/PreviewNav.astro';
import { en as t } from '../../i18n/en';
---

<BaseLayout
  lang="en"
  title="Sidebar Preview – tomatenstau.de"
  description="Sidebar layout preview"
  skipToMain="Skip to main content"
>
  <div class="layout">
    <!-- Fixed left sidebar -->
    <aside class="sidebar" aria-label="Profile sidebar">
      <div class="sidebar__inner">
        <picture>
          <source srcset="/images/profilbild.webp" type="image/webp" />
          <img
            src="/images/profilbild.jpg"
            alt={t.index.profilePhotoAlt}
            class="sidebar__photo"
            width="140"
            height="140"
            loading="eager"
            fetchpriority="high"
          />
        </picture>

        <div class="sidebar__badge">🟢 Available for projects</div>

        <h1 class="sidebar__name">{t.index.name}</h1>
        <p class="sidebar__title">{t.index.jobTitle}</p>

        <nav class="sidebar__social" aria-label="Social links">
          <a href={t.social.github.url} target="_blank" rel="noopener noreferrer">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="15"
              height="15"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
              ></path></svg
            >
            GitHub
          </a>
          <a href={t.social.linkedin.url} target="_blank" rel="noopener noreferrer">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="15"
              height="15"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path></svg
            >
            LinkedIn
          </a>
          <a href={t.social.email.url}>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="15"
              height="15"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"
              ></path></svg
            >
            E-Mail
          </a>
        </nav>

        <hr class="sidebar__rule" />

        <div class="sidebar__meta">
          <span class="sidebar__meta-label">Location</span>
          <span>Germany 🇩🇪</span>
        </div>
        <div class="sidebar__meta">
          <span class="sidebar__meta-label">Languages</span>
          <span>Deutsch · English</span>
        </div>
        <div class="sidebar__meta">
          <span class="sidebar__meta-label">Experience</span>
          <span>12+ years</span>
        </div>

        <hr class="sidebar__rule" />

        <div class="sidebar__currently">
          <span class="sidebar__meta-label">Currently</span>
          <p>
            Leading architecture for a distributed IoT platform and building out an internal AI
            team.
          </p>
        </div>

        <hr class="sidebar__rule" />

        <div class="sidebar__tags" aria-label="Key topics">
          {
            ['Architecture', 'Team Lead', 'IoT', 'API Design', 'CI/CD', 'AI', 'DDD', 'iSAQB'].map(
              (tag) => <span class="tag">{tag}</span>,
            )
          }
        </div>
      </div>
    </aside>

    <!-- Scrollable main content -->
    <main id="main-content" class="content">
      <section aria-labelledby="about-heading">
        <h2 id="about-heading" class="section-title">About</h2>
        <p class="lead">{t.index.intro}</p>
        <p class="body-text">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque habitant morbi
          tristique senectus et netus et malesuada fames ac turpis egestas. Praesent suscipit purus
          at orci lacinia, eu dictum enim posuere. Vivamus ultricies felis et nunc fermentum, nec
          condimentum eros feugiat. Sed porttitor leo a tortor sagittis, vel pretium orci bibendum.
        </p>
      </section>

      <hr class="content__rule" />

      <section aria-labelledby="experience-heading">
        <h2 id="experience-heading" class="section-title">Experience</h2>
        <ol class="timeline" role="list">
          <li class="timeline__item">
            <div class="timeline__dot" aria-hidden="true"></div>
            <div class="timeline__body">
              <div class="timeline__header">
                <strong class="timeline__role">Team Lead Manager &amp; Solution Architect</strong>
                <span class="timeline__period">2021 – present</span>
              </div>
              <p class="timeline__company">Lorem Ipsum Technologies GmbH · Full-time</p>
              <p class="timeline__desc">
                Architecting and evolving a distributed IoT platform serving 500+ industrial
                clients. Leading a cross-functional team of 12 engineers across backend, platform,
                and AI. Responsible for target pictures, quarterly roadmaps, and stakeholder
                alignment across product, IT, and C-level.
              </p>
              <div class="timeline__tags">
                {
                  ['Architecture', 'Team Lead', 'IoT', 'AI', 'Roadmap'].map((t) => (
                    <span class="tl-tag">{t}</span>
                  ))
                }
              </div>
            </div>
          </li>
          <li class="timeline__item">
            <div class="timeline__dot" aria-hidden="true"></div>
            <div class="timeline__body">
              <div class="timeline__header">
                <strong class="timeline__role">Senior Software Architect</strong>
                <span class="timeline__period">2018 – 2021</span>
              </div>
              <p class="timeline__company">Dolor Sit AG · Industry Division</p>
              <p class="timeline__desc">
                Designed microservice architecture for a real-time MQTT/OPC-UA data platform.
                Defined integration strategies for legacy ERP systems. Conducted architecture
                reviews and introduced event-driven patterns that reduced latency by 40%.
              </p>
              <div class="timeline__tags">
                {
                  ['Microservices', 'MQTT', 'Spring Boot', 'Event Sourcing'].map((t) => (
                    <span class="tl-tag">{t}</span>
                  ))
                }
              </div>
            </div>
          </li>
          <li class="timeline__item">
            <div class="timeline__dot" aria-hidden="true"></div>
            <div class="timeline__body">
              <div class="timeline__header">
                <strong class="timeline__role">Software Engineer</strong>
                <span class="timeline__period">2015 – 2018</span>
              </div>
              <p class="timeline__company">Consectetur Solutions · E-Commerce</p>
              <p class="timeline__desc">
                Full-stack development of a high-traffic e-commerce platform. Migrated monolith to
                service-oriented architecture. Improved checkout conversion by 18% through
                performance optimisation and A/B testing infrastructure.
              </p>
              <div class="timeline__tags">
                {
                  ['Node.js', 'Angular', 'MySQL', 'Redis'].map((t) => (
                    <span class="tl-tag">{t}</span>
                  ))
                }
              </div>
            </div>
          </li>
          <li class="timeline__item timeline__item--last">
            <div class="timeline__dot" aria-hidden="true"></div>
            <div class="timeline__body">
              <div class="timeline__header">
                <strong class="timeline__role">Junior Developer</strong>
                <span class="timeline__period">2012 – 2015</span>
              </div>
              <p class="timeline__company">Adipiscing Digital · Web &amp; Mobile</p>
              <p class="timeline__desc">
                Developed client-facing web applications and internal tooling. First exposure to
                agile methodologies, continuous integration, and cross-browser frontend work.
              </p>
            </div>
          </li>
        </ol>
      </section>

      <hr class="content__rule" />

      <section aria-labelledby="skills-heading">
        <h2 id="skills-heading" class="section-title">Skills</h2>
        <div class="skills-grid">
          <div class="skill-group">
            <h3 class="skill-group__label">{t.index.highlights.focus}</h3>
            <p>{t.index.highlights.focusText}</p>
          </div>
          <div class="skill-group">
            <h3 class="skill-group__label">{t.index.highlights.tech}</h3>
            <p>{t.index.highlights.techText}</p>
          </div>
          <div class="skill-group">
            <h3 class="skill-group__label">{t.index.highlights.platforms}</h3>
            <p>{t.index.highlights.platformsText}</p>
          </div>
          <div class="skill-group">
            <h3 class="skill-group__label">{t.index.highlights.domains}</h3>
            <p>{t.index.highlights.domainsText}</p>
          </div>
          <div class="skill-group skill-group--full">
            <h3 class="skill-group__label">{t.index.highlights.certs}</h3>
            <p>{t.index.highlights.certsText}</p>
          </div>
        </div>
      </section>

      <hr class="content__rule" />

      <section aria-labelledby="contact-heading" class="contact-section">
        <h2 id="contact-heading" class="section-title">Get in touch</h2>
        <p class="body-text">
          Interested in working together, discussing architecture challenges, or just saying hello?
          Feel free to reach out via any of the channels below.
        </p>
        <div class="contact-links">
          <a href={t.social.email.url} class="contact-btn contact-btn--primary"> Send an e-mail </a>
          <a
            href={t.social.linkedin.url}
            target="_blank"
            rel="noopener noreferrer"
            class="contact-btn"
          >
            Connect on LinkedIn
          </a>
        </div>
      </section>
    </main>
  </div>

  <PreviewNav current="sidebar" />
</BaseLayout>

<style>
  :global(body) {
    margin: 0;
  }

  .layout {
    display: flex;
    min-height: 100vh;
    background: #0d1b2a;
    color: #a8b8cc;
    font-family: 'Merriweather', serif;
  }

  /* ── Sidebar ── */
  .sidebar {
    width: 270px;
    flex-shrink: 0;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    background: #071220;
    border-right: 1px solid #1a2d42;
  }

  .sidebar__inner {
    padding: 36px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .sidebar__photo {
    width: 110px;
    height: 110px;
    border-radius: 12px;
    object-fit: cover;
    border: 2px solid #1a2d42;
    margin-bottom: 2px;
  }

  .sidebar__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-family: system-ui, sans-serif;
    color: #4ade80;
    background: rgba(74, 222, 128, 0.1);
    border: 1px solid rgba(74, 222, 128, 0.2);
    border-radius: 999px;
    padding: 3px 10px;
    width: fit-content;
  }

  .sidebar__name {
    font-family: 'Raleway', sans-serif;
    font-size: 18px;
    color: #e2eaf3;
    margin: 4px 0 0;
  }

  .sidebar__title {
    font-size: 11px;
    color: #4a9eff;
    margin: 0;
    line-height: 1.5;
    font-family: system-ui, sans-serif;
  }

  .sidebar__rule {
    border: none;
    border-top: 1px solid #1a2d42;
    margin: 6px 0;
  }

  .sidebar__social {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sidebar__social a {
    display: flex;
    align-items: center;
    gap: 9px;
    color: #6a82a0;
    text-decoration: none;
    font-size: 12px;
    font-family: system-ui, sans-serif;
    padding: 5px 8px;
    border-radius: 6px;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .sidebar__social a:hover {
    background: #1a2d42;
    color: #e2eaf3;
  }

  .sidebar__meta {
    display: flex;
    flex-direction: column;
    gap: 1px;
    font-size: 12px;
    font-family: system-ui, sans-serif;
    color: #7a92a8;
  }

  .sidebar__meta-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #4a9eff;
  }

  .sidebar__currently {
    font-size: 12px;
    font-family: system-ui, sans-serif;
    color: #6a82a0;
    line-height: 1.6;
  }

  .sidebar__currently p {
    margin: 4px 0 0;
  }

  .sidebar__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .tag {
    font-size: 10px;
    font-family: system-ui, sans-serif;
    font-weight: 600;
    background: #0f1f30;
    border: 1px solid #1a2d42;
    color: #6a9ec8;
    border-radius: 4px;
    padding: 2px 7px;
  }

  /* ── Content ── */
  .content {
    flex: 1;
    padding: 56px 64px 80px;
    max-width: 800px;
  }

  .section-title {
    font-family: system-ui, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #4a9eff;
    margin: 0 0 24px;
  }

  .content__rule {
    border: none;
    border-top: 1px solid #1a2d42;
    margin: 48px 0;
  }

  .lead {
    font-size: 15px;
    line-height: 1.9;
    color: #8eacc8;
    margin: 0 0 16px;
  }

  .body-text {
    font-size: 14px;
    line-height: 1.9;
    color: #5a7290;
    margin: 0;
  }

  /* ── Timeline ── */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: #1a2d42;
  }

  .timeline__item {
    display: flex;
    gap: 20px;
    padding-bottom: 36px;
    position: relative;
  }

  .timeline__item--last {
    padding-bottom: 0;
  }

  .timeline__dot {
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: #0d1b2a;
    border: 2px solid #4a9eff;
    flex-shrink: 0;
    margin-top: 3px;
    position: relative;
    z-index: 1;
  }

  .timeline__body {
    flex: 1;
  }

  .timeline__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 4px;
  }

  .timeline__role {
    color: #c8daf0;
    font-size: 15px;
    font-weight: 700;
    font-family: 'Raleway', sans-serif;
  }

  .timeline__period {
    font-size: 12px;
    color: #4a9eff;
    font-family: system-ui, sans-serif;
    white-space: nowrap;
  }

  .timeline__company {
    font-size: 12px;
    color: #4a6a88;
    font-family: system-ui, sans-serif;
    margin: 0 0 8px;
  }

  .timeline__desc {
    font-size: 13px;
    line-height: 1.8;
    color: #5a7290;
    margin: 0 0 10px;
  }

  .timeline__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .tl-tag {
    font-size: 10px;
    font-family: system-ui, sans-serif;
    font-weight: 600;
    background: #0a1520;
    border: 1px solid #1a2d42;
    color: #4a7aaa;
    border-radius: 4px;
    padding: 2px 8px;
  }

  /* ── Skills ── */
  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .skill-group {
    background: #091525;
    border: 1px solid #1a2d42;
    border-radius: 8px;
    padding: 16px 18px;
    font-size: 13px;
    line-height: 1.7;
    color: #5a7290;
  }

  .skill-group--full {
    grid-column: 1 / -1;
  }

  .skill-group__label {
    font-family: system-ui, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #4a9eff;
    margin: 0 0 8px;
  }

  .skill-group p {
    margin: 0;
  }

  /* ── Contact ── */
  .contact-section {
    padding-bottom: 40px;
  }
  .contact-links {
    display: flex;
    gap: 12px;
    margin-top: 20px;
    flex-wrap: wrap;
  }

  .contact-btn {
    display: inline-block;
    font-family: system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.2s;
    border: 1px solid #1a2d42;
    color: #8eacc8;
  }

  .contact-btn:hover {
    opacity: 0.75;
  }
  .contact-btn--primary {
    background: #4a9eff;
    color: #fff;
    border-color: #4a9eff;
  }

  @media (max-width: 860px) {
    .layout {
      flex-direction: column;
    }
    .sidebar {
      width: 100%;
      height: auto;
      position: static;
    }
    .content {
      padding: 32px 24px;
    }
    .skills-grid {
      grid-template-columns: 1fr;
    }
    .skill-group--full {
      grid-column: 1;
    }
  }
</style>
