---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PreviewNav from '../../components/PreviewNav.astro';
import { en as t } from '../../i18n/en';
---

<BaseLayout
  lang="en"
  title="Hero Preview – tomatenstau.de"
  description="Hero layout preview"
  skipToMain="Skip to main content"
>
  <main id="main-content">
    <section class="hero" aria-labelledby="hero-name">
      <div class="hero__inner">
        <picture class="hero__photo-wrap">
          <source srcset="/images/profilbild.webp" type="image/webp" />
          <img
            src="/images/profilbild.jpg"
            alt={t.index.profilePhotoAlt}
            class="hero__photo"
            width="160"
            height="160"
            loading="eager"
            fetchpriority="high"
          />
        </picture>

        <h1 id="hero-name">{t.index.name}</h1>
        <p class="hero__title">{t.index.jobTitle}</p>

        <nav class="hero__social" aria-label="Social links">
          <a
            href={t.social.github.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t.social.github.label}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="22"
              height="22"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
              ></path></svg
            >
          </a>
          <a
            href={t.social.linkedin.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t.social.linkedin.label}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="22"
              height="22"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path></svg
            >
          </a>
          <a href={t.social.email.url} aria-label={t.social.email.label}>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="22"
              height="22"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"
              ></path></svg
            >
          </a>
        </nav>

        <a href="#highlights" class="hero__scroll" aria-label="Scroll to highlights">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="24"
            height="24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"></path></svg
          >
        </a>
      </div>
    </section>

    <section id="highlights" class="highlights" aria-labelledby="highlights-heading">
      <div class="highlights__inner">
        <h2 id="highlights-heading" class="highlights__heading">{t.index.highlightsHeading}</h2>
        <p class="highlights__intro">{t.index.intro}</p>
        <ul class="highlights__grid" role="list">
          <li class="highlights__card">
            <span class="highlights__label">{t.index.highlights.focus}</span>
            <span>{t.index.highlights.focusText}</span>
          </li>
          <li class="highlights__card">
            <span class="highlights__label">{t.index.highlights.tech}</span>
            <span>{t.index.highlights.techText}</span>
          </li>
          <li class="highlights__card">
            <span class="highlights__label">{t.index.highlights.platforms}</span>
            <span>{t.index.highlights.platformsText}</span>
          </li>
          <li class="highlights__card">
            <span class="highlights__label">{t.index.highlights.domains}</span>
            <span>{t.index.highlights.domainsText}</span>
          </li>
          <li class="highlights__card highlights__card--wide">
            <span class="highlights__label">{t.index.highlights.certs}</span>
            <span>{t.index.highlights.certsText}</span>
          </li>
        </ul>
      </div>
    </section>
  </main>

  <PreviewNav current="hero" />
</BaseLayout>

<style>
  main {
    background: #060d14;
    color: #c9d1d9;
    font-family: 'Merriweather', serif;
  }

  /* ── Hero ── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 60px 24px;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(0, 210, 190, 0.08) 0%, transparent 70%),
      #060d14;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    max-width: 600px;
  }

  .hero__photo-wrap {
    display: block;
  }

  .hero__photo {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid rgba(0, 210, 190, 0.4);
    box-shadow:
      0 0 0 6px rgba(0, 210, 190, 0.08),
      0 20px 60px rgba(0, 0, 0, 0.6);
  }

  h1 {
    font-family: 'Raleway', sans-serif;
    font-size: clamp(32px, 6vw, 52px);
    color: #fff;
    margin: 8px 0 0;
    letter-spacing: -1px;
  }

  .hero__title {
    font-family: system-ui, sans-serif;
    font-size: 16px;
    color: #00d2be;
    margin: 0;
    letter-spacing: 0.5px;
  }

  .hero__social {
    display: flex;
    gap: 20px;
    margin-top: 8px;
  }

  .hero__social a {
    color: rgba(255, 255, 255, 0.5);
    display: flex;
    transition:
      color 0.2s,
      transform 0.2s;
  }

  .hero__social a:hover {
    color: #00d2be;
    transform: translateY(-2px);
  }

  .hero__scroll {
    margin-top: 32px;
    color: rgba(255, 255, 255, 0.3);
    display: flex;
    animation: bounce 2s ease-in-out infinite;
    transition: color 0.2s;
  }

  .hero__scroll:hover {
    color: #00d2be;
  }

  @keyframes bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }

  /* ── Highlights ── */
  .highlights {
    padding: 80px 24px;
    background: #0d1117;
  }

  .highlights__inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .highlights__heading {
    font-family: 'Raleway', sans-serif;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #00d2be;
    margin: 0 0 16px;
  }

  .highlights__intro {
    font-size: 15px;
    line-height: 1.8;
    color: #8b949e;
    margin: 0 0 40px;
    max-width: 680px;
  }

  .highlights__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .highlights__card {
    background: #161b22;
    border: 1px solid #21262d;
    border-radius: 10px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 14px;
    line-height: 1.6;
    transition: border-color 0.2s;
  }

  .highlights__card:hover {
    border-color: rgba(0, 210, 190, 0.3);
  }

  .highlights__card--wide {
    grid-column: 1 / -1;
  }

  .highlights__label {
    font-family: system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #00d2be;
  }

  @media (max-width: 600px) {
    .highlights__grid {
      grid-template-columns: 1fr;
    }
    .highlights__card--wide {
      grid-column: 1;
    }
  }
</style>
