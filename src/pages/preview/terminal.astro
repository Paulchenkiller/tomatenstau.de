        <!-- links -->
        <div class="line mt">
          <span class="prompt">meik@ts</span><span class="px">:</span><span class="wd">~</span><span
            class="px">$</span
          >
          <span class="cmd">./links --open</span>
        </div>
        <ul class="output link-list" role="list">
          <li>
            <span class="link-label">[github] </span><a
              href={t.social.github.url}
              target="_blank"
              rel="noopener noreferrer">{t.social.github.url}</a
            >
          </li>
          <li>
            <span class="link-label">[linkedin]</span><a
              href={t.social.linkedin.url}
              target="_blank"
              rel="noopener noreferrer">{t.social.linkedin.url}</a
