---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PreviewNav from '../../components/PreviewNav.astro';
import { en as t } from '../../i18n/en';

const skills = t.index.highlights.techText.split(', ');
const platforms = t.index.highlights.platformsText.split(', ');
---

<BaseLayout
  lang="en"
  title="Terminal Preview – tomatenstau.de"
  description="Terminal layout preview"
  skipToMain="Skip to main content"
>
  <fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </fragment>

  <main id="main-content" class="terminal-page">
    <div class="terminal" role="region" aria-label="Terminal interface">
      <div class="terminal__bar" aria-hidden="true">
        <span class="dot dot--red"></span>
        <span class="dot dot--yellow"></span>
        <span class="dot dot--green"></span>
        <span class="terminal__title">meik@tomatenstau.de — bash</span>
      </div>

      <div class="terminal__body">
        <div class="line">
          <span class="prompt" aria-hidden="true">~</span>
          <span class="cmd">whoami</span>
        </div>
        <p class="output output--highlight">{t.index.name}</p>
        <p class="output">{t.index.jobTitle}</p>

        <div class="line mt">
          <span class="prompt" aria-hidden="true">~</span>
          <span class="cmd">cat about.txt</span>
        </div>
        <p class="output output--muted">{t.index.intro}</p>

        <div class="line mt">
          <span class="prompt" aria-hidden="true">~</span>
          <span class="cmd">skills --list</span>
        </div>
        <div class="output">
          <div class="skill-grid" role="list" aria-label="Technical skills">
            {
              skills.map((s) => (
                <span class="skill-item" role="listitem">
                  {s}
                </span>
              ))
            }
            {
              platforms.map((p) => (
                <span class="skill-item skill-item--dim" role="listitem">
                  {p}
                </span>
              ))
            }
          </div>
        </div>

        <div class="line mt">
          <span class="prompt" aria-hidden="true">~</span>
          <span class="cmd">cat certs.txt</span>
        </div>
        <p class="output output--muted">{t.index.highlights.certsText}</p>

        <div class="line mt">
          <span class="prompt" aria-hidden="true">~</span>
          <span class="cmd">./links --open</span>
        </div>
        <ul class="output link-list" role="list">
          <li>
            <span class="link-label" aria-hidden="true">[github] </span>
            <a href={t.social.github.url} target="_blank" rel="noopener noreferrer"
              >{t.social.github.url}</a
            >
          </li>
          <li>
            <span class="link-label" aria-hidden="true">[linkedin]</span>
            <a href={t.social.linkedin.url} target="_blank" rel="noopener noreferrer"
              >{t.social.linkedin.url}</a
            >
          </li>
          <li>
            <span class="link-label" aria-hidden="true">[mail] </span>
            <a href={t.social.email.url}>{t.social.email.url}</a>
          </li>
        </ul>

        <div class="line mt">
          <span class="prompt" aria-hidden="true">~</span>
          <span class="cursor" aria-hidden="true">█</span>
        </div>
      </div>
    </div>
  </main>

  <PreviewNav current="terminal" />
</BaseLayout>

<style>
  .terminal-page {
    min-height: 100vh;
    background: #0c0c0c;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 24px 100px;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
  }

  .terminal {
    width: 100%;
    max-width: 820px;
    background: #141414;
    border-radius: 10px;
    border: 1px solid #2a2a2a;
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.8);
    overflow: hidden;
  }

  .terminal__bar {
    background: #252525;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid #2a2a2a;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .dot--red {
    background: #ff5f56;
  }
  .dot--yellow {
    background: #ffbd2e;
  }
  .dot--green {
    background: #27c93f;
  }

  .terminal__title {
    flex: 1;
    text-align: center;
    font-size: 12px;
    color: #666;
    margin-left: -44px;
  }

  .terminal__body {
    padding: 24px 28px 32px;
    line-height: 1.7;
    font-size: 14px;
  }

  .line {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .mt {
    margin-top: 24px;
  }

  .prompt {
    color: #27c93f;
    font-weight: 700;
    user-select: none;
  }

  .cmd {
    color: #e2e2e2;
  }

  .output {
    margin: 6px 0 0 0;
    padding-left: 22px;
    color: #9e9e9e;
  }

  .output--highlight {
    color: #27c93f;
    font-weight: 700;
    font-size: 18px;
  }

  .output--muted {
    color: #666;
    font-size: 13px;
    line-height: 1.8;
  }

  .skill-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }

  .skill-item {
    background: #1e2a1e;
    color: #27c93f;
    border: 1px solid #2a3d2a;
    border-radius: 4px;
    padding: 2px 10px;
    font-size: 12px;
  }

  .skill-item--dim {
    background: #1a1a1a;
    color: #555;
    border-color: #222;
  }

  .link-list {
    list-style: none;
    padding-left: 22px;
    margin: 6px 0 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 13px;
  }

  .link-list li {
    display: flex;
    gap: 10px;
  }

  .link-label {
    color: #27c93f;
    white-space: pre;
    flex-shrink: 0;
  }

  .link-list a {
    color: #4fc3f7;
    text-decoration: none;
    transition: color 0.2s;
  }

  .link-list a:hover {
    color: #81d4fa;
    text-decoration: underline;
  }

  .cursor {
    color: #27c93f;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  @media (max-width: 600px) {
    .terminal__body {
      padding: 16px;
      font-size: 13px;
    }
  }
</style>
