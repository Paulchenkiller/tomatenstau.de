          <span class="prompt">meik@ts</span><span class="px">:</span><span class="wd">~</span><span
            class="px">$</span
          >
          <span class="cmd">chafa --colors=256 --size=32x16 ~/images/profilbild.jpg</span>
        </div>
        <div class="output chafa-output" role="img" aria-label={t.index.profilePhotoAlt}>
          <div class="chafa-frame">
            <div class="chafa-frame__top" aria-hidden="true">
              в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
            </div>
            <div class="chafa-frame__mid">
              <span class="chafa-frame__side" aria-hidden="true">в”Ӯ </span>
              <picture>
                <source srcset="/images/profilbild.webp" type="image/webp" />
