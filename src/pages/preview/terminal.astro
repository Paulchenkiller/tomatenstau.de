        <p class="output output--name">{t.index.name}</p>
        <p class="output output--muted">{t.index.jobTitle}</p>

        <!-- uptime -->
        <div class="line mt">
          <span class="prompt">meik@ts</span><span class="px">:</span><span class="wd">~</span><span
            class="px">$</span
          >
          <span class="cmd">uptime</span>
        </div>
        <p class="output output--muted">
          up 12+ years &nbsp;В·&nbsp; load average: <span class="uptime-tag">deadlines</span>, <span
            class="uptime-tag">coffee</span
          >, <span class="uptime-tag">architecture</span>
        </p>

        <!-- about -->
        <div class="line mt">
          <span class="prompt">meik@ts</span><span class="px">:</span><span class="wd">~</span><span
            class="px">$</span
          >
          <span class="cmd">cat about.txt</span>
        </div>
        <p class="output output--body">
          I design and evolve scalable system architectures, define target pictures and roadmaps,
          and lead cross-functional teams вҖ” including an AI team. My work spans architecture
          reviews, security and quality gates, API and IoT integration strategies, and shipping
          efficient CI/CD pipelines with full observability. I bridge product, business, and IT.
        </p>

        <!-- experience -->
        <div class="line mt">
          <span class="prompt">meik@ts</span><span class="px">:</span><span class="wd">~</span><span
            class="px">$</span
          >
          <span class="cmd">cat experience.txt</span>
        </div>
        <div class="output">
          <table class="exp-table" aria-label="Experience timeline">
            <tr>
              <td class="exp-year">2021 вҖ“ now</td>
              <td class="exp-sep">в”Ӯ</td>
              <td
                ><span class="exp-title">Team Lead Manager & Solution Architect</span><br /><span
                  class="exp-company">Lorem Ipsum Technologies GmbH</span
                ></td
              >
            </tr>
            <tr>
              <td class="exp-year">2018 вҖ“ 2021</td>
              <td class="exp-sep">в”Ӯ</td>
              <td
                ><span class="exp-title">Senior Software Architect</span><br /><span
                  class="exp-company">Dolor Sit AG вҖ” Industry / IoT Division</span
                ></td
              >
            </tr>
            <tr>
              <td class="exp-year">2015 вҖ“ 2018</td>
              <td class="exp-sep">в”Ӯ</td>
              <td
                ><span class="exp-title">Software Engineer (Java / Node.js)</span><br /><span
                  class="exp-company">Consectetur Solutions вҖ” E-Commerce Platform</span
                ></td
              >
            </tr>
            <tr>
              <td class="exp-year">2012 вҖ“ 2015</td>
              <td class="exp-sep">в”Ӯ</td>
              <td
                ><span class="exp-title">Junior Developer</span><br /><span class="exp-company"
                  >Adipiscing Digital вҖ” Web & Mobile</span
                ></td
              >
            </tr>
          </table>
        </div>

        <!-- ls projects -->
        <div class="line mt">
          <span class="prompt">meik@ts</span><span class="px">:</span><span class="wd">~</span><span
            class="px">$</span
          >
          <span class="cmd">ls projects/</span>
        </div>
        <div class="output ls-output" aria-label="Project list">
          <span class="ls-dir">iot-platform/</span>
          <span class="ls-dir">ai-team-infra/</span>
          <span class="ls-dir">api-gateway/</span>
          <span class="ls-file">arch-review-2024.pdf</span>
          <span class="ls-file">roadmap-q1-2025.md</span>
          <span class="ls-dir">tomatenstau.de/</span>
        </div>

        <!-- skills -->
        <div class="line mt">
          <span class="prompt">meik@ts</span><span class="px">:</span><span class="wd">~</span><span
            class="px">$</span
          >
          <span class="cmd">skills --list --verbose</span>
        </div>
        <div class="output">
          <p class="sk-group-label"># Languages & Frameworks</p>
          <div class="skill-grid">
            {skills.map((s) => <span class="skill-item">{s}</span>)}
          </div>
          <p class="sk-group-label"># Platforms & Infrastructure</p>
          <div class="skill-grid">
            {platforms.map((p) => <span class="skill-item skill-item--dim">{p}</span>)}
          </div>
        </div>

        <!-- tree skills -->
        <div class="line mt">
          <span class="prompt">meik@ts</span><span class="px">:</span><span class="wd">~</span><span
            class="px">$</span
          >
          <span class="cmd">tree ~/skills</span>
        </div>
        <pre
          class="output tree-output"
          aria-label="Skills tree">{`~/skills
в”ңв”Җв”Җ architecture/
в”Ӯ   в”ңв”Җв”Җ hexagonal
в”Ӯ   в”ңв”Җв”Җ clean
в”Ӯ   в””в”Җв”Җ event-driven
в”ңв”Җв”Җ languages/
в”Ӯ   в”ңв”Җв”Җ TypeScript вҳ…
в”Ӯ   в”ңв”Җв”Җ Java
в”Ӯ   в””в”Җв”Җ Python
в”ңв”Җв”Җ platforms/
в”Ӯ   в”ңв”Җв”Җ AWS
в”Ӯ   в”ңв”Җв”Җ Kubernetes
в”Ӯ   в””в”Җв”Җ GitHub-Actions
в””в”Җв”Җ soft/
    в”ңв”Җв”Җ team-lead
    в”ңв”Җв”Җ stakeholder-mgmt
    в””в”Җв”Җ arch-reviews

4 directories, 13 files`}</pre>

        <!-- git log -->
        <div class="line mt">
          <span class="prompt">meik@ts</span><span class="px">:</span><span class="wd"
            >~/tomatenstau.de</span
          ><span class="px">$</span>
          <span class="cmd">git log --oneline -6</span>
        </div>
        <div class="output git-log" aria-label="Recent commits">
          <div class="git-row">
            <span class="git-hash">a7bc7b9</span><span class="git-msg"
              >fix(e2e): remove stale XING assertion after social link removal</span
            >
          </div>
          <div class="git-row">
            <span class="git-hash">317d658</span><span class="git-msg"
              >fix: move CNAME to public/ so it is included in Astro dist output</span
