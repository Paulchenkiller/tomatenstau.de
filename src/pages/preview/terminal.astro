            <span class="chafa-meta__file">profilbild.jpg</span>
            <span class="chafa-meta__sep">В·</span>
            <span>300Г—300</span>
            <span class="chafa-meta__sep">В·</span>
            <span>JPEG</span>
            <span class="chafa-meta__sep">В·</span>
            <span class="chafa-meta__ok">вң“ rendered via chafa 1.14</span>
