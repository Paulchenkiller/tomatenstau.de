---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PreviewNav from '../../components/PreviewNav.astro';
import { en as t } from '../../i18n/en';

const skills = t.index.highlights.techText.split(', ');
const platforms = t.index.highlights.platformsText.split(', ');
---

<BaseLayout
  lang="en"
  title="Terminal Preview вҖ“ tomatenstau.de"
  description="Terminal layout preview"
  skipToMain="Skip to main content"
>
  <fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </fragment>

  <main id="main-content" class="terminal-page">
    <div class="terminal" role="region" aria-label="Terminal interface">
      <!-- Title bar -->
      <div class="terminal__bar" aria-hidden="true">
        <span class="dot dot--red"></span>
        <span class="dot dot--yellow"></span>
        <span class="dot dot--green"></span>
        <span class="terminal__title">meik@tomatenstau.de вҖ” bash вҖ” 120Г—40</span>
      </div>

      <div class="terminal__body">
        <!-- neofetch-style block -->
        <div class="neofetch" aria-label="System info">
          <pre
            class="neofetch__ascii"
            aria-hidden="true">{`в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—
в–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в•қ
в–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ
в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв–Ҳв–Ҳв•—
в–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•—
в•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ`}</pre>
          <div class="neofetch__info">
            <p>
              <span class="nf-key">user</span><span class="nf-sep">@</span><span class="nf-key"
                >host</span
              > &nbsp;<span class="nf-val">meik@tomatenstau.de</span>
            </p>
            <p class="nf-rule">в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ</p>
            <p>
              <span class="nf-key">role</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <span class="nf-val"
                >Software & Solution Architect</span
              >
            </p>
            <p>
              <span class="nf-key">title</span>&nbsp;&nbsp;&nbsp;&nbsp; <span class="nf-val"
                >Team Lead Manager</span
              >
            </p>
            <p><span class="nf-key">location</span>&nbsp; <span class="nf-val">Germany рҹҮ©рҹҮӘ</span></p>
            <p>
              <span class="nf-key">lang</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <span class="nf-val"
                >DE В· EN</span
              >
            </p>
            <p>
              <span class="nf-key">certs</span>&nbsp;&nbsp;&nbsp;&nbsp; <span class="nf-val"
                >iSAQB CPSA-A В· CPSA-F</span
              >
            </p>
            <p>
              <span class="nf-key">stack</span>&nbsp;&nbsp;&nbsp;&nbsp; <span class="nf-val"
                >Astro В· TS В· Java В· Python</span
              >
            </p>
            <div class="nf-colors" aria-hidden="true">
