          </div>
          <div class="git-row">
            <span class="git-hash">e58d0be</span><span class="git-msg"
              >fix: header nav flex, redesign 404 page</span
            >
          </div>
          <div class="git-row">
            <span class="git-hash">c6f7592</span><span class="git-msg"
              >chore: remove Angular, Express SSR and legacy CSS</span
            >
          </div>
          <div class="git-row">
            <span class="git-hash">b4b4b08</span><span class="git-msg"
              >fix: lcp image loading, redundant aria roles, add hreflang</span
            >
          </div>
        </div>

        <!-- alias -->
        <div class="line mt">
          <span class="prompt">meik@ts</span><span class="px">:</span><span class="wd">~</span><span
            class="px">$</span
          >
          <span class="cmd">alias</span>
        </div>
        <div class="output alias-output">
          <div class="alias-row">
            <span class="alias-name">deploy</span><span class="alias-eq">=</span><span
              class="alias-val">'./ship.sh --check --confirm'</span
            >
          </div>
          <div class="alias-row">
            <span class="alias-name">think</span><span class="alias-eq">=</span><span
              class="alias-val">'coffee && sleep 300 && echo ready'</span
            >
          </div>
          <div class="alias-row">
            <span class="alias-name">meetings</span><span class="alias-eq">=</span><span
              class="alias-val">'cal --week && focus-mode on'</span
