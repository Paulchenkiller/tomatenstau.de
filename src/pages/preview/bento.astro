---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PreviewNav from '../../components/PreviewNav.astro';
import { en as t } from '../../i18n/en';
---

<BaseLayout
  lang="en"
  title="Bento Preview – tomatenstau.de"
  description="Bento grid layout preview"
  skipToMain="Skip to main content"
>
  <main id="main-content">
    <div class="page">
      <div class="bento" role="region" aria-label="Profile overview">
        <!-- Card: Photo + Name -->
        <div class="card card--identity">
          <picture>
            <source srcset="/images/profilbild.webp" type="image/webp" />
            <img
              src="/images/profilbild.jpg"
              alt={t.index.profilePhotoAlt}
              class="photo"
              width="120"
              height="120"
              loading="eager"
              fetchpriority="high"
            />
          </picture>
          <div>
            <h1>{t.index.name}</h1>
            <p class="title">{t.index.jobTitle}</p>
          </div>
        </div>

        <!-- Card: Intro -->
        <div class="card card--intro">
          <span class="tag">About</span>
          <p>{t.index.intro}</p>
        </div>

        <!-- Card: Focus -->
        <div class="card card--focus">
          <span class="tag">{t.index.highlights.focus}</span>
          <p>{t.index.highlights.focusText}</p>
        </div>

        <!-- Card: Tech chips -->
        <div class="card card--tech">
          <span class="tag">{t.index.highlights.tech}</span>
          <ul class="chips" role="list">
            {t.index.highlights.techText.split(', ').map((chip) => <li class="chip">{chip}</li>)}
          </ul>
        </div>

        <!-- Card: Social links -->
        <div class="card card--social">
          <span class="tag">Links</span>
          <div class="social-links">
            <a
              href={t.social.github.url}
              target="_blank"
              rel="noopener noreferrer"
              class="social-btn"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                width="20"
                height="20"
                fill="currentColor"
                aria-hidden="true"
                ><path
                  d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                ></path></svg
              >
              GitHub
            </a>
            <a
              href={t.social.linkedin.url}
              target="_blank"
              rel="noopener noreferrer"
              class="social-btn"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                width="20"
                height="20"
                fill="currentColor"
                aria-hidden="true"
                ><path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path></svg
              >
              LinkedIn
            </a>
            <a href={t.social.email.url} class="social-btn">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                width="20"
                height="20"
                fill="currentColor"
                aria-hidden="true"
                ><path
                  d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"
                ></path></svg
              >
              E-Mail
            </a>
          </div>
        </div>

        <!-- Card: Platforms -->
        <div class="card card--platforms">
          <span class="tag">{t.index.highlights.platforms}</span>
          <p>{t.index.highlights.platformsText}</p>
        </div>

        <!-- Card: Certs -->
        <div class="card card--certs">
          <span class="tag">{t.index.highlights.certs}</span>
          <p>{t.index.highlights.certsText}</p>
        </div>
      </div>
    </div>
  </main>

  <PreviewNav current="bento" />
</BaseLayout>

<style>
  main {
    min-height: 100vh;
    background: #0a0e1a;
    font-family: system-ui, sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 24px 100px;
  }

  .page {
    width: 100%;
    max-width: 960px;
  }

  .bento {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: minmax(80px, auto);
    gap: 14px;
  }

  .card {
    background: #111827;
    border: 1px solid #1f2a3c;
    border-radius: 16px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    color: #9ca3af;
    font-size: 14px;
    line-height: 1.6;
    transition:
      border-color 0.25s,
      transform 0.25s;
  }

  .card:hover {
    border-color: #3b4f6b;
    transform: translateY(-2px);
  }

  .tag {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #4f8ef7;
  }

  /* Layout assignments */
  .card--identity {
    grid-column: span 5;
    grid-row: span 2;
    flex-direction: row;
    align-items: center;
    gap: 20px;
  }
  .card--intro {
    grid-column: span 7;
    grid-row: span 2;
  }
  .card--focus {
    grid-column: span 4;
  }
  .card--tech {
    grid-column: span 4;
  }
  .card--social {
    grid-column: span 4;
  }
  .card--platforms {
    grid-column: span 6;
  }
  .card--certs {
    grid-column: span 6;
  }

  /* Identity card */
  .photo {
    width: 100px;
    height: 100px;
    border-radius: 12px;
    object-fit: cover;
    flex-shrink: 0;
    border: 1px solid #1f2a3c;
  }

  h1 {
    font-family: 'Raleway', sans-serif;
    font-size: 22px;
    color: #f3f4f6;
    margin: 0 0 4px;
  }

  .title {
    font-size: 13px;
    color: #4f8ef7;
    margin: 0;
    line-height: 1.5;
  }

  /* Tech chips */
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .chip {
    background: #1f2a3c;
    border: 1px solid #2d3d55;
    border-radius: 6px;
    padding: 3px 10px;
    font-size: 12px;
    color: #93c5fd;
  }

  /* Social */
  .social-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .social-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #9ca3af;
    text-decoration: none;
    font-size: 14px;
    padding: 6px 10px;
    border-radius: 8px;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .social-btn:hover {
    background: #1f2a3c;
    color: #f3f4f6;
  }

  @media (max-width: 700px) {
    .bento {
      grid-template-columns: 1fr;
    }
    .card--identity,
    .card--intro,
    .card--focus,
    .card--tech,
    .card--social,
    .card--platforms,
    .card--certs {
      grid-column: 1;
      grid-row: auto;
    }
    .card--identity {
      flex-direction: column;
    }
  }
</style>
