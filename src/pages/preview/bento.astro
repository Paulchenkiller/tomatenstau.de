---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PreviewNav from '../../components/PreviewNav.astro';
import { en as t } from '../../i18n/en';
---

<BaseLayout
  lang="en"
  title="Bento Preview – tomatenstau.de"
  description="Bento grid layout preview"
  skipToMain="Skip to main content"
>
  <main id="main-content">
    <div class="page">
      <div class="bento" role="region" aria-label="Profile overview">
        <!-- Identity card (large, top-left) -->
        <div class="card card--identity">
          <picture>
            <source srcset="/images/profilbild.webp" type="image/webp" />
            <img
              src="/images/profilbild.jpg"
              alt={t.index.profilePhotoAlt}
              class="photo"
              width="90"
              height="90"
              loading="eager"
              fetchpriority="high"
            />
          </picture>
          <div class="identity__text">
            <h1>{t.index.name}</h1>
            <p class="identity__title">{t.index.jobTitle}</p>
            <div class="identity__badge">🟢 Available</div>
          </div>
        </div>

        <!-- About / intro (spans wide) -->
        <div class="card card--about">
          <span class="tag">About</span>
          <p class="about-lead">{t.index.intro}</p>
          <p class="about-body">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vivamus lacinia odio vitae
            vestibulum. Donec in efficitur leo. Praesent commodo cursus magna, vel scelerisque nisl
            consectetur — architecting systems that last.
          </p>
        </div>

        <!-- Stats card -->
        <div class="card card--stats">
          <span class="tag">By the numbers</span>
          <div class="stats-grid">
            <div class="stat">
              <span class="stat__num">12+</span>
              <span class="stat__label">Years exp.</span>
            </div>
            <div class="stat">
              <span class="stat__num">3</span>
              <span class="stat__label">iSAQB certs</span>
            </div>
            <div class="stat">
              <span class="stat__num">50+</span>
              <span class="stat__label">Projects</span>
            </div>
            <div class="stat">
              <span class="stat__num">12</span>
              <span class="stat__label">Team size</span>
            </div>
          </div>
        </div>

        <!-- Currently working on -->
        <div class="card card--currently">
          <span class="tag">Currently</span>
          <p class="currently__item">
            <span class="currently__icon" aria-hidden="true">⚡</span>
            Leading architecture for a distributed IoT platform serving 500+ industrial clients
          </p>
          <p class="currently__item">
            <span class="currently__icon" aria-hidden="true">🤖</span>
            Building out an internal AI team — tooling, workflows, and governance
          </p>
          <p class="currently__item">
            <span class="currently__icon" aria-hidden="true">🌐</span>
            Migrating personal site to Astro (you're looking at it)
          </p>
        </div>

        <!-- Tech chips -->
        <div class="card card--tech">
          <span class="tag">{t.index.highlights.tech}</span>
          <ul class="chips" role="list">
            {t.index.highlights.techText.split(', ').map((chip) => <li class="chip">{chip}</li>)}
          </ul>
          <span class="tag" style="margin-top: 8px">{t.index.highlights.platforms}</span>
          <ul class="chips chips--dim" role="list">
            {
              t.index.highlights.platformsText
                .split(', ')
                .map((chip) => <li class="chip chip--dim">{chip}</li>)
            }
          </ul>
        </div>

        <!-- Social links -->
        <div class="card card--social">
          <span class="tag">Links</span>
          <div class="social-links">
            <a
              href={t.social.github.url}
              target="_blank"
              rel="noopener noreferrer"
              class="social-btn"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                width="18"
                height="18"
                fill="currentColor"
                aria-hidden="true"
                ><path
                  d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                ></path></svg
              >
              <span>GitHub</span>
              <span class="social-btn__sub">Paulchenkiller</span>
            </a>
            <a
              href={t.social.linkedin.url}
              target="_blank"
              rel="noopener noreferrer"
              class="social-btn"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                width="18"
                height="18"
                fill="currentColor"
                aria-hidden="true"
                ><path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path></svg
              >
              <span>LinkedIn</span>
              <span class="social-btn__sub">meik-geldmacher</span>
            </a>
            <a href={t.social.email.url} class="social-btn">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                width="18"
                height="18"
                fill="currentColor"
                aria-hidden="true"
                ><path
                  d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"
                ></path></svg
              >
              <span>E-Mail</span>
              <span class="social-btn__sub">meik@tomatenstau.de</span>
            </a>
          </div>
        </div>

        <!-- Focus / domains -->
        <div class="card card--focus">
          <span class="tag">{t.index.highlights.focus}</span>
          <p>{t.index.highlights.focusText}</p>
          <span class="tag" style="margin-top: 8px">{t.index.highlights.domains}</span>
          <p>{t.index.highlights.domainsText}</p>
        </div>

        <!-- Quote card -->
        <div class="card card--quote">
          <blockquote class="quote">
            <p>
              "Good architecture is less about the tools you choose and more about the decisions
              you're able to defer — and the ones you've consciously made."
            </p>
            <footer>— Lorem Ipsum, fictitious architect</footer>
          </blockquote>
        </div>

        <!-- Location + availability -->
        <div class="card card--location">
          <span class="tag">Where &amp; When</span>
          <div class="location-info">
            <p><span class="loc-icon" aria-hidden="true">📍</span> Germany (CET/CEST)</p>
            <p><span class="loc-icon" aria-hidden="true">🗓️</span> Open to remote &amp; hybrid</p>
            <p><span class="loc-icon" aria-hidden="true">🌐</span> DE · EN</p>
          </div>
        </div>

        <!-- Certs -->
        <div class="card card--certs">
          <span class="tag">{t.index.highlights.certs}</span>
          <p>{t.index.highlights.certsText}</p>
          <div class="cert-badges" aria-hidden="true">
            <span class="cert-badge">CPSA-A</span>
            <span class="cert-badge">DDD</span>
            <span class="cert-badge">CLOUDINFRA</span>
            <span class="cert-badge">ARCEVAL</span>
            <span class="cert-badge">CPSA-F</span>
          </div>
        </div>
      </div>
    </div>
  </main>

  <PreviewNav current="bento" />
</BaseLayout>

<style>
  main {
    min-height: 100vh;
    background: #080c14;
    font-family: system-ui, sans-serif;
    padding: 40px 24px 120px;
  }

  .page {
    max-width: 1080px;
    margin: 0 auto;
  }

  .bento {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: minmax(60px, auto);
    gap: 12px;
  }

  /* ── Card base ── */
  .card {
    background: #0f1623;
    border: 1px solid #1c2a3e;
    border-radius: 16px;
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    color: #8ca0bb;
    font-size: 13.5px;
    line-height: 1.65;
    transition:
      border-color 0.25s,
      transform 0.2s;
  }

  .card:hover {
    border-color: #2d4264;
    transform: translateY(-2px);
  }

  .card p {
    margin: 0;
  }

  .tag {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: #4f8ef7;
  }

  /* ── Grid layout ── */
  .card--identity {
    grid-column: span 4;
    flex-direction: row;
    align-items: center;
    gap: 18px;
    background: linear-gradient(135deg, #0f1623 60%, #111e35);
  }
  .card--about {
    grid-column: span 8;
  }
  .card--stats {
    grid-column: span 4;
  }
  .card--currently {
    grid-column: span 4;
  }
  .card--tech {
    grid-column: span 4;
  }
  .card--social {
    grid-column: span 3;
  }
  .card--focus {
    grid-column: span 5;
  }
  .card--quote {
    grid-column: span 4;
    background: linear-gradient(135deg, #0a1628, #0f1f3a);
    border-color: #1e3558;
  }
  .card--location {
    grid-column: span 3;
  }
  .card--certs {
    grid-column: span 5;
  }

  /* ── Identity ── */
  .photo {
    width: 80px;
    height: 80px;
    border-radius: 12px;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid #1c2a3e;
  }

  .identity__text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  h1 {
    font-family: 'Raleway', sans-serif;
    font-size: 19px;
    color: #dce8f5;
    margin: 0;
  }

  .identity__title {
    font-size: 11px;
    color: #4f8ef7;
    line-height: 1.4;
    margin: 0;
  }

  .identity__badge {
    font-size: 10px;
    font-weight: 600;
    color: #4ade80;
    background: rgba(74, 222, 128, 0.08);
    border: 1px solid rgba(74, 222, 128, 0.18);
    border-radius: 999px;
    padding: 2px 9px;
    width: fit-content;
    margin-top: 2px;
  }

  /* ── About ── */
  .about-lead {
    color: #7a9ab8;
    font-size: 13px;
    line-height: 1.8;
  }

  .about-body {
    color: #4a6080;
    font-size: 12.5px;
    line-height: 1.8;
    font-style: italic;
  }

  /* ── Stats ── */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 4px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px;
    background: #080c14;
    border: 1px solid #1c2a3e;
    border-radius: 10px;
    text-align: center;
  }

  .stat__num {
    font-family: 'Raleway', sans-serif;
    font-size: 26px;
    font-weight: 800;
    color: #4f8ef7;
    line-height: 1;
  }

  .stat__label {
    font-size: 10px;
    color: #4a6080;
    letter-spacing: 0.5px;
  }

  /* ── Currently ── */
  .currently__item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13px;
    color: #7a9ab8;
    line-height: 1.55;
  }

  .currently__icon {
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ── Chips ── */
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .chip {
    background: #111e35;
    border: 1px solid #1e3255;
    border-radius: 6px;
    padding: 3px 9px;
    font-size: 11px;
    color: #7ab4f7;
  }

  .chip--dim {
    background: #0c1520;
    border-color: #151f2e;
    color: #3a5070;
  }

  /* ── Social ── */
  .social-links {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .social-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #8ca0bb;
    text-decoration: none;
    font-size: 13px;
    padding: 8px 10px;
    border-radius: 8px;
    border: 1px solid transparent;
    transition:
      background 0.2s,
      border-color 0.2s,
      color 0.2s;
    flex-wrap: wrap;
  }

  .social-btn:hover {
    background: #111e35;
    border-color: #1c2a3e;
    color: #dce8f5;
  }

  .social-btn__sub {
    font-size: 11px;
    color: #3a5070;
    margin-left: auto;
  }

  /* ── Quote ── */
  .quote {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    height: 100%;
    justify-content: center;
  }

  .quote p {
    font-size: 14px;
    line-height: 1.8;
    color: #6a8ab0;
    font-style: italic;
    margin: 0;
  }

  .quote footer {
    font-size: 11px;
    color: #2d4264;
    font-style: normal;
  }

  /* ── Location ── */
  .location-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 13px;
    color: #6a8ab0;
  }
  .location-info p {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .loc-icon {
    flex-shrink: 0;
  }

  /* ── Certs ── */
  .cert-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }

  .cert-badge {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    background: #0a1628;
    border: 1px solid #1e3558;
    color: #4f8ef7;
    border-radius: 6px;
    padding: 3px 10px;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .bento {
      grid-template-columns: repeat(6, 1fr);
    }
    .card--identity {
      grid-column: span 6;
    }
    .card--about {
      grid-column: span 6;
    }
    .card--stats {
      grid-column: span 3;
    }
    .card--currently {
      grid-column: span 3;
    }
    .card--tech {
      grid-column: span 6;
    }
    .card--social {
      grid-column: span 3;
    }
    .card--focus {
      grid-column: span 3;
    }
    .card--quote {
      grid-column: span 6;
    }
    .card--location {
      grid-column: span 3;
    }
    .card--certs {
      grid-column: span 3;
    }
  }

  @media (max-width: 560px) {
    .bento {
      grid-template-columns: 1fr;
    }
    .card--identity {
      flex-direction: column;
    }
    .card--stats {
      grid-column: 1;
    }
    .card--currently,
    .card--tech,
    .card--social,
    .card--focus,
    .card--quote,
    .card--location,
    .card--certs {
      grid-column: 1;
    }
  }
</style>
