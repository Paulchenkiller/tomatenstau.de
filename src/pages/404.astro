---
import BaseLayout from '../layouts/BaseLayout.astro';
import { en as t } from '../i18n/en';
---

<BaseLayout
  lang="en"
  title={`404 – ${t.notFound.title}`}
  description={t.notFound.subtitle}
  skipToMain="Skip to main content"
>
  <main id="main-content">
    <div class="not-found">
      <h1>{t.notFound.title}</h1>
      <p>{t.notFound.subtitle}</p>
      <a href="/">{t.notFound.backHome}</a>
    </div>
  </main>
</BaseLayout>

<style>
  main {
    padding-top: 120px;
    padding-bottom: 88px;
    min-height: 100vh;
    background: var(--app-bg);
  }

  .not-found {
    text-align: center;
    padding: 48px 24px;
  }

  .not-found h1 {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .not-found p {
    color: var(--text-muted);
    margin-bottom: 32px;
  }

  .not-found a {
    display: inline-block;
    background: var(--green);
    color: #fff;
    padding: 10px 20px;
    border-radius: 4px;
    text-decoration: none;
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    transition: background 0.2s;
  }

  .not-found a:hover,
  .not-found a:focus {
    background: var(--green-hover);
    color: #fff;
  }
</style>
