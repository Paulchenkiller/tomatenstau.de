---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { en as t } from '../i18n/en';
---

<BaseLayout
  lang="en"
  title={`404 – ${t.notFound.title}`}
  description={t.notFound.subtitle}
  skipToMain="Skip to main content"
>
  <Header lang="en" t={{ header: t.header, site: t.site, social: t.social }} />

  <main id="main-content">
    <div class="not-found">
      <span class="not-found__code" aria-hidden="true">404</span>
      <h1>{t.notFound.title}</h1>
      <p>{t.notFound.subtitle}</p>
      <a href="/">{t.notFound.backHome}</a>
    </div>
  </main>

  <Footer t={{ footer: t.footer, social: t.social }} />
</BaseLayout>

<style>
  main {
    padding-top: 120px;
    padding-bottom: 88px;
    min-height: 100vh;
    background: var(--app-bg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .not-found {
    text-align: center;
    padding: 24px;
  }

  .not-found__code {
    display: block;
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: clamp(96px, 20vw, 160px);
    line-height: 1;
    color: var(--green);
    opacity: 0.25;
    margin-bottom: 16px;
    letter-spacing: -4px;
  }

  .not-found h1 {
    font-size: clamp(22px, 4vw, 32px);
    margin: 0 0 12px;
    color: var(--heading);
  }

  .not-found p {
    color: var(--text-muted);
    margin: 0 0 32px;
    font-size: 16px;
  }

  .not-found a {
    display: inline-block;
    background: var(--green);
    color: #fff;
    padding: 10px 24px;
    border-radius: 4px;
    text-decoration: none;
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    transition: background 0.2s;
  }

  .not-found a:hover,
  .not-found a:focus {
    background: var(--green-hover);
    color: #fff;
  }
</style>
