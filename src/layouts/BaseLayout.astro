---
import '../styles/global.css';

interface Props {
  lang: string;
  title: string;
  description: string;
  skipToMain: string;
}
const { lang, title, description, skipToMain } = Astro.props;
---

<!doctype html>
<!--
  hey, you found the source. nice.

   _
  ( )
  | |_ ___  _ __ ___   __ _| |_ ___ _ __  ___| |_ __ _ _   _
  | __/ _ \| '_ ` _ \ / _` | __/ _ \ '_ \/ __| __/ _` | | | |
  | || (_) | | | | | | (_| | ||  __/ | | \__ \ || (_| | |_| |
   \__\___/|_| |_| |_|\__,_|\__\___|_| |_|___/\__\__,_|\__,_|

   github.com/Paulchenkiller/tomatenstau.de
-->
<html lang={lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="alternate" hreflang="en" href="https://tomatenstau.de/" />
    <link rel="alternate" hreflang="x-default" href="https://tomatenstau.de/" />

    <!-- Favicons -->
    <link href="/favicon/favicon-32x32.png" rel="icon" sizes="32x32" type="image/png" />
    <link href="/favicon/favicon-16x16.png" rel="icon" sizes="16x16" type="image/png" />
    <link href="/favicon/apple-touch-icon.png" rel="apple-touch-icon" sizes="180x180" />
    <link href="/favicon/android-chrome-192x192.png" rel="icon" sizes="192x192" type="image/png" />
    <link href="/favicon/android-chrome-512x512.png" rel="icon" sizes="512x512" type="image/png" />
    <meta name="theme-color" content="#111417" />

    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">{skipToMain}</a>
    <slot />
  </body>
</html>
