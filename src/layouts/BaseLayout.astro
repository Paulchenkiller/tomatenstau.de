---
import '../styles/global.css';

interface Props {
  lang: 'en' | 'de';
  title: string;
  description: string;
  skipToMain: string;
}
const { lang, title, description, skipToMain } = Astro.props;
---

<!doctype html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Hreflang alternate links -->
    <link rel="alternate" hreflang="en" href="https://tomatenstau.de/" />
    <link rel="alternate" hreflang="de" href="https://tomatenstau.de/de/" />
    <link rel="alternate" hreflang="x-default" href="https://tomatenstau.de/" />

    <!-- Favicons -->
    <link href="/favicon/favicon-32x32.png" rel="icon" sizes="32x32" type="image/png" />
    <link href="/favicon/favicon-16x16.png" rel="icon" sizes="16x16" type="image/png" />
    <link href="/favicon/apple-touch-icon.png" rel="apple-touch-icon" sizes="180x180" />
    <link href="/favicon/android-chrome-192x192.png" rel="icon" sizes="192x192" type="image/png" />
    <link href="/favicon/android-chrome-512x512.png" rel="icon" sizes="512x512" type="image/png" />
    <meta name="theme-color" content="#111417" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/raleway/v37/1Ptxg8zYS_SKggPN4iEgvnHyvveLxVtapbCIPrE.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Merriweather&family=Raleway:wght@800&display=swap"
      rel="stylesheet"
    />

    <!-- High-contrast init: runs before first paint to prevent flash -->
    <script is:inline>
      (function () {
        var cookieMatch = document.cookie.match(/(?:^|;\s*)pref:high-contrast=([^;]+)/);
        var saved = cookieMatch ? cookieMatch[1] : null;
        if (!saved) {
          try {
            saved = localStorage.getItem('pref:high-contrast');
          } catch (_) {}
        }
        var usesSystem =
          !saved && window.matchMedia && window.matchMedia('(prefers-contrast: more)').matches;
        if (saved === 'on' || usesSystem) {
          document.documentElement.setAttribute('data-theme', 'hc');
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">{skipToMain}</a>
    <slot />
  </body>
</html>
