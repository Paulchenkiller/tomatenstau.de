---
import type { Translations } from '../i18n/en';

interface Props {
  lang: 'en' | 'de';
  t: Pick<Translations, 'header' | 'site' | 'social'>;
}
const { lang, t } = Astro.props;
const homeUrl = lang === 'en' ? '/' : '/de/';
---

<header id="main-header" role="banner">
  <div class="header-row">
    <div class="logo">
      <a href={homeUrl} aria-label={t.header.homeLinkLabel} title={t.header.homeLinkLabel}>
        <picture>
          <source srcset="/images/tomatenstau_logo.webp" type="image/webp" />
          <img src="/images/tomatenstau_logo.png" alt="" width="160" height="75" loading="eager" />
        </picture>
        <span class="visually-hidden">{t.site.name}</span>
      </a>
    </div>

    <nav id="main-nav" role="navigation" aria-label={t.header.mainNavLabel}>
      <ul class="header-social" role="list">
        <li role="listitem">
          <a
            href={t.social.github.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${t.social.github.label} – ${t.header.opensInNewWindow}`}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="currentColor"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
          </a>
        </li>
        <li role="listitem">
          <a
            href={t.social.linkedin.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${t.social.linkedin.label} – ${t.header.opensInNewWindow}`}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="currentColor"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>
        </li>
        <li role="listitem">
          <a
            href={t.social.xing.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${t.social.xing.label} – ${t.header.opensInNewWindow}`}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="currentColor"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M18.188 0c-.517 0-.741.325-.927.66 0 0-7.455 13.224-7.702 13.657.015.024 4.919 9.023 4.919 9.023.17.308.436.66.967.66h3.454c.211 0 .375-.078.463-.22.089-.151.089-.346-.009-.536l-4.879-8.916c-.004-.006-.004-.016 0-.022L22.139.756c.095-.191.097-.387.006-.535C22.056.078 21.894 0 21.686 0h-3.498zM3.648 4.74c-.211 0-.385.074-.473.216-.09.149-.078.339.02.531l2.34 4.05c.004.01.004.016 0 .021L1.86 16.051c-.099.188-.093.381 0 .529.085.142.239.234.45.234h3.461c.518 0 .766-.348.945-.667l3.734-6.609-2.378-4.155c-.172-.315-.434-.643-.962-.643H3.648z"
              ></path>
            </svg>
          </a>
        </li>
      </ul>
    </nav>

    <ul class="header-lang" aria-label={t.header.langSwitcherLabel} role="list">
      <li role="listitem">
        <a
          href="/"
          class:list={['lang-btn', { active: lang === 'en' }]}
          title="English"
          aria-label={t.header.switchToEn}
          data-lang="en"
          aria-current={lang === 'en' ? 'true' : undefined}
        >
          <span class="flag flag-gb" aria-hidden="true"></span>
        </a>
      </li>
      <li role="listitem">
        <a
          href="/de/"
          class:list={['lang-btn', { active: lang === 'de' }]}
          title="Deutsch"
          aria-label={t.header.switchToDe}
          data-lang="de"
          aria-current={lang === 'de' ? 'true' : undefined}
        >
          <span class="flag flag-de" aria-hidden="true"></span>
        </a>
      </li>
      <li role="listitem">
        <button
          id="hc-toggle"
          type="button"
          title={t.header.highContrast}
          aria-label={t.header.toggleHighContrast}
          aria-pressed="false"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="20"
            height="20"
            fill="currentColor"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18V4c4.41 0 8 3.59 8 8s-3.59 8-8 8z"
            ></path>
          </svg>
        </button>
      </li>
    </ul>
  </div>
</header>

<script>
  document.querySelectorAll<HTMLAnchorElement>('.lang-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const lang = btn.dataset.lang;
      if (lang) {
        try {
          localStorage.setItem('lang', lang);
        } catch (_) {}
        document.cookie = `lang=${lang};path=/;max-age=${365 * 24 * 3600};SameSite=Lax`;
      }
    });
  });

  const hcBtn = document.getElementById('hc-toggle') as HTMLButtonElement | null;
  if (hcBtn) {
    const isHC = document.documentElement.getAttribute('data-theme') === 'hc';
    hcBtn.setAttribute('aria-pressed', String(isHC));
    hcBtn.addEventListener('click', () => {
      const next = document.documentElement.getAttribute('data-theme') !== 'hc';
      document.documentElement.setAttribute('data-theme', next ? 'hc' : '');
      hcBtn.setAttribute('aria-pressed', String(next));
      const val = next ? 'on' : 'off';
      try {
        localStorage.setItem('pref:high-contrast', val);
      } catch (_) {}
      document.cookie = `pref:high-contrast=${val};path=/;max-age=${365 * 24 * 3600};SameSite=Lax`;
    });
  }
</script>

<style>
  header {
    height: 90px;
    width: 100%;
    position: fixed;
    left: 0;
    top: 0;
    z-index: 600;
    background-color: var(--header-bg);
  }

  .header-row {
    display: flex;
    align-items: center;
    height: 100%;
    padding: 0 20px;
  }

  .logo {
    flex-shrink: 0;
    margin-right: 30px;
  }

  .logo a {
    display: flex;
    align-items: center;
    height: 75px;
    border: none;
    text-decoration: none;
  }

  .logo img {
    height: 75px;
    width: 160px;
    object-fit: contain;
  }

  nav {
    flex: 1;
  }

  .header-social {
    display: flex;
    align-items: center;
    gap: 15px;
    font-size: 20px;
  }

  .header-social a {
    color: #f4f1de;
    display: flex;
    transition: color 0.2s ease;
  }

  .header-social a:hover,
  .header-social a:focus {
    color: var(--green);
  }

  .header-lang {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-left: auto;
  }

  .lang-btn {
    display: flex;
    align-items: center;
    background: transparent;
    border: none;
    cursor: pointer;
    color: #f4f1de;
    opacity: 0.75;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .lang-btn.active,
  .lang-btn:hover,
  .lang-btn:focus {
    opacity: 1;
    color: var(--green);
  }

  #hc-toggle {
    background: transparent;
    border: none;
    cursor: pointer;
    color: #f4f1de;
    opacity: 0.75;
    display: flex;
    align-items: center;
    font-size: 22px;
    transition: opacity 0.2s ease;
    padding: 2px;
  }

  #hc-toggle:hover,
  #hc-toggle:focus {
    opacity: 1;
    color: var(--green);
  }

  .flag {
    display: inline-block;
    width: 22px;
    height: 16px;
    border-radius: 2px;
    background-size: cover;
    background-position: center;
    vertical-align: -2px;
  }

  .flag-gb {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 60 36'><rect width='60' height='36' fill='%23012169'/><path stroke='%23FFF' stroke-width='8' d='M0,0 L60,36 M60,0 L0,36'/><path stroke='%23C8102E' stroke-width='4' d='M0,0 L60,36 M60,0 L0,36'/><rect x='0' y='14' width='60' height='8' fill='%23FFF'/><rect x='26' y='0' width='8' height='36' fill='%23FFF'/><rect x='0' y='16' width='60' height='4' fill='%23C8102E'/><rect x='28' y='0' width='4' height='36' fill='%23C8102E'/></svg>");
  }

  .flag-de {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 18'><rect width='30' height='18' fill='%23000'/><rect y='6' width='30' height='6' fill='%23dd0000'/><rect y='12' width='30' height='6' fill='%23ffce00'/></svg>");
  }

  :global([data-theme='hc']) header {
    background-color: #000 !important;
  }

  :global([data-theme='hc']) .header-social a,
  :global([data-theme='hc']) .lang-btn,
  :global([data-theme='hc']) #hc-toggle {
    color: #fff !important;
    opacity: 1 !important;
  }

  @media (max-width: 880px) {
    .header-social {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .header-row {
      padding: 0 10px;
    }

    .logo {
      margin-left: -10px;
    }
  }

  @media (max-width: 454px) {
    .logo img {
      width: 100px;
      height: 65px;
    }

    #hc-toggle {
      font-size: 20px;
    }
  }
</style>
