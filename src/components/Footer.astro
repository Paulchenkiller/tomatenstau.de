---
import type { Translations } from '../i18n/en';

interface Props {
  t: Pick<Translations, 'footer' | 'social'>;
}
const { t } = Astro.props;
---

<footer>
  <div class="footer-inner">
    <ul class="social-links" role="list">
      <li role="listitem">
        <a
          href={t.social.email.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t.social.email.label}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="24"
            height="24"
            fill="currentColor"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"
            ></path>
          </svg>
        </a>
      </li>
      <li role="listitem">
        <a
          href={t.social.github.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t.social.github.label}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="24"
            height="24"
            fill="currentColor"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
        </a>
      </li>
      <li role="listitem">
        <a
          href={t.social.linkedin.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t.social.linkedin.label}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="24"
            height="24"
            fill="currentColor"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </a>
      </li>
      <li role="listitem">
        <a
          href={t.social.xing.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t.social.xing.label}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="24"
            height="24"
            fill="currentColor"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M18.188 0c-.517 0-.741.325-.927.66 0 0-7.455 13.224-7.702 13.657.015.024 4.919 9.023 4.919 9.023.17.308.436.66.967.66h3.454c.211 0 .375-.078.463-.22.089-.151.089-.346-.009-.536l-4.879-8.916c-.004-.006-.004-.016 0-.022L22.139.756c.095-.191.097-.387.006-.535C22.056.078 21.894 0 21.686 0h-3.498zM3.648 4.74c-.211 0-.385.074-.473.216-.09.149-.078.339.02.531l2.34 4.05c.004.01.004.016 0 .021L1.86 16.051c-.099.188-.093.381 0 .529.085.142.239.234.45.234h3.461c.518 0 .766-.348.945-.667l3.734-6.609-2.378-4.155c-.172-.315-.434-.643-.962-.643H3.648z"
            ></path>
          </svg>
        </a>
      </li>
    </ul>
    <p class="copyright">{t.footer.copyright}</p>
  </div>
</footer>

<style>
  footer {
    padding: 8px 0 12px;
    position: fixed;
    left: 0;
    bottom: 0;
    width: 100%;
    z-index: 600;
    background: var(--app-bg);
    border-top: 1px solid var(--border);
    color: var(--text-muted);
  }

  .footer-inner {
    text-align: center;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin: 6px 0 2px;
    padding: 0;
  }

  .social-links a {
    color: rgba(255, 255, 255, 0.8);
    display: flex;
    align-items: center;
    transition: color 0.2s ease;
  }

  .social-links a:hover,
  .social-links a:focus {
    color: var(--green);
  }

  .copyright {
    margin: 4px 0 0;
    padding: 0;
    font:
      12px/18px 'Raleway',
      sans-serif;
    letter-spacing: 0.5px;
    color: var(--text-muted);
  }

  :global([data-theme='hc']) footer {
    background: #000 !important;
    border-top: 1px solid #666 !important;
  }

  :global([data-theme='hc']) .social-links a {
    color: #fff !important;
    text-decoration: underline;
  }

  :global([data-theme='hc']) .copyright {
    color: #e0e0e0 !important;
  }

  @media (max-width: 600px) {
    .social-links {
      gap: 12px;
    }
  }
</style>
