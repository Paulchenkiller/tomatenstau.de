---
interface Props {
  current: 'hero' | 'bento' | 'sidebar' | 'terminal' | 'minimal';
}
const { current } = Astro.props;

const variants = [
  { id: 'hero', label: 'Hero' },
  { id: 'bento', label: 'Bento' },
  { id: 'sidebar', label: 'Sidebar' },
  { id: 'terminal', label: 'Terminal' },
  { id: 'minimal', label: 'Minimal' },
] as const;
---

<nav class="preview-nav" aria-label="Layout previews">
  <a href="/preview/" class="preview-nav__home">← Übersicht</a>
  <div class="preview-nav__items">
    {
      variants.map((v) => (
        <a
          href={`/preview/${v.id}/`}
          class:list={['preview-nav__item', { active: v.id === current }]}
        >
          {v.label}
        </a>
      ))
    }
  </div>
</nav>

<style>
  .preview-nav {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(0, 0, 0, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    padding: 8px 16px;
    backdrop-filter: blur(12px);
    font-family: system-ui, sans-serif;
    font-size: 13px;
    white-space: nowrap;
  }

  .preview-nav__home {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    padding-right: 8px;
    border-right: 1px solid rgba(255, 255, 255, 0.15);
    transition: color 0.2s;
  }

  .preview-nav__home:hover {
    color: #fff;
  }

  .preview-nav__items {
    display: flex;
    gap: 4px;
  }

  .preview-nav__item {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    padding: 3px 10px;
    border-radius: 999px;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .preview-nav__item:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  .preview-nav__item.active {
    color: #000;
    background: #fff;
    font-weight: 600;
  }
</style>
