---
import Layout from "../layouts/Layout.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import { useTranslations } from "../i18n/ui";
import { Image } from "astro:assets";
import profileImg from "../assets/images/optimized/profilbild.jpg";

interface Props {
  lang: "en" | "de";
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<Layout
  title={t("INDEX.NAME") + " – " + t("INDEX.TITLE")}
  description={t("INDEX.INTRO")}
  lang={lang}
>
  <Header lang={lang} />

  <main
    id="main-content"
    role="main"
    aria-label={t("CONTENT.ARIA.MAIN_CONTENT")}
  >
    <section class="intro" aria-labelledby="main-heading">
      <div class="container">
        <div class="intro__media">
          <Image
            src={profileImg}
            alt={t("INDEX.ARIA.PROFILE_PHOTO")}
            class="intro__photo"
            width={300}
            height={300}
            loading="eager"
          />
        </div>
        <div class="intro__content">
          <h1 id="main-heading">{t("INDEX.NAME")}</h1>
          <h2 class="intro__title">{t("INDEX.TITLE")}</h2>
          <p class="lead">{t("INDEX.INTRO")}</p>

          <section aria-labelledby="highlights-heading">
            <h3 id="highlights-heading" class="visually-hidden">
              {t("INDEX.ARIA.HIGHLIGHTS_HEADING")}
            </h3>
            <ul class="intro__highlights" role="list">
              <li role="listitem">
                <strong>{t("INDEX.HIGHLIGHTS.FOCUS")}</strong>
                {" "}{t("INDEX.HIGHLIGHTS.FOCUS_TEXT")}
              </li>
              <li role="listitem">
                <strong>{t("INDEX.HIGHLIGHTS.TECH")}</strong>
                {" "}{t("INDEX.HIGHLIGHTS.TECH_TEXT")}
              </li>
              <li role="listitem">
                <strong>{t("INDEX.HIGHLIGHTS.PLATFORMS")}</strong>
                {" "}{t("INDEX.HIGHLIGHTS.PLATFORMS_TEXT")}
              </li>
              <li role="listitem">
                <strong>{t("INDEX.HIGHLIGHTS.DOMAINS")}</strong>
                {" "}{t("INDEX.HIGHLIGHTS.DOMAINS_TEXT")}
              </li>
              <li role="listitem">
                <strong>{t("INDEX.HIGHLIGHTS.CERTS")}</strong>
                {" "}{t("INDEX.HIGHLIGHTS.CERTS_TEXT")}
              </li>
            </ul>
          </section>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</Layout>

<style lang="scss">
  @use "../styles/colors.scss" as colors;

  .intro {
    background: colors.$bg;
    padding-top: 0;
  }

  .intro .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 24px;
    display: grid;
    grid-template-columns: 220px 1fr;
    grid-gap: 32px;
    align-items: start;
  }

  .intro__media {
    contain: layout style;
    width: 220px;
    height: 250px;
  }

  .intro__photo {
    width: 100%;
    height: 100%;
    max-width: 220px;
    object-fit: cover;
    border-radius: 8px;
    display: block;
    margin-top: 10px; /* align with h1 top margin to keep photo and text level */
    border: 1px solid colors.$border;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.25);
  }

  /* Reduce headline sizes locally for the intro section */
  .intro__content h1 {
    font-size: 26px;
    line-height: 32px;
    margin: 6px 0 6px;
  }

  .intro__title {
    color: colors.$accent_muted;
    font-weight: 800;
    margin-top: 4px;
  }

  .lead {
    color: colors.$text_muted;
  }

  .intro__highlights {
    margin: 16px 0 24px;
    padding-left: 20px;
    color: colors.$text_secondary;
    list-style: disc;
    list-style-position: outside;
    text-align: left;
  }

  .intro__highlights li {
    margin: 6px 0;
  }

  .btn {
    display: inline-block;
    background: colors.$green;
    color: colors.$white_full;
    padding: 10px 16px;
    margin-right: 12px;
    border-radius: 4px;
    text-decoration: none;
  }

  .btn:hover {
    background: colors.$green_hover;
  }

  .btn--ghost {
    background: transparent;
    border: 1px solid colors.$green;
    color: colors.$white_full;
  }

  @media (max-width: 800px) {
    .intro .container {
      grid-template-columns: 1fr;
      text-align: center;
    }
    /* Keep highlights left-aligned on small screens */
    .intro__highlights {
      text-align: left;
      margin-left: auto;
      margin-right: auto;
    }
    .intro__media {
      order: -1;
      width: 200px;
      height: 230px;
      margin: 0 auto;
    }
    .intro__photo {
      margin: 10px auto 16px;
    }
  }
</style>
